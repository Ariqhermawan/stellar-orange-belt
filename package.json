{
  "name": "stellar-orange-belt",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "description": "Stellar Soroban crowdfunding dApp: two contracts (PLEDGE token + crowdfund) with cross-contract token transfers, multi-wallet connect, faucet, contribute/claim/refund, live events, and transaction status tracking on testnet.",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
